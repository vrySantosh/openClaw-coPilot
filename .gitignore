# ==========================
# OpenClaw Setup Repository
# ==========================
# This .gitignore is designed to prevent ANY sensitive or runtime
# data from being accidentally committed to a public repository.

# Sensitive credentials & tokens
credentials/
identity/
devices/

# Agent auth profiles (contain API tokens)
agents/*/agent/auth-profiles.json

# Agent session transcripts (may contain private conversations)
agents/*/sessions/

# Agent model configs (generated per-install)
agents/*/agent/models.json

# Live config with real tokens — use openclaw.example.json as template
openclaw.json
openclaw.json.bak*

# Exec approvals (contains socket token)
exec-approvals.json
exec-approvals.sock

# Runtime logs
logs/
executor-log.txt
integration.log

# Installed OpenClaw binary and libraries (large, install via `npm i -g openclaw`)
bin/
lib/

# Bundled tools (large binaries)
tools/

# Runtime workspace & state
workspace/
vscode-workspace/
canvas/
cron/
settings/
delivery-queue/

# Update check state
update-check.json

# macOS metadata
.DS_Store
**/.DS_Store

# VS Code workspace settings
.vscode/

# Shell completions (auto-generated)
completions/

# Voice-local: whisper.cpp source/build (large, cloned by install.sh)
voice-local/whisper.cpp/

# Memory (runtime agent memory)
memory/

# Node
node_modules/
media/
